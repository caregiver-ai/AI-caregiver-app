{
  "id": "gavin-clean",
  "nameHint": "Gavin",
  "turns": [
    {
      "id": "gavin-clean-1",
      "role": "user",
      "promptType": "section_prompt",
      "content": "Gavin is non-speaking and uses an AAC device on an iPad with TouchChat. He uses it to ask for help, request car rides, and tell us when he wants his iPad. He may also lead you to what he needs or sit close when he wants attention. He does not tell you if he is hurt or needs the bathroom.",
      "createdAt": "2026-04-16T00:00:00.000Z",
      "stepId": "communication",
      "stepTitle": "Communication",
      "promptLabel": "Communication"
    },
    {
      "id": "gavin-clean-2",
      "role": "user",
      "promptType": "section_prompt",
      "content": "Visual choices, two-step directions, quiet low-light environments, and a structured routine help the day go well. Food needs to stay available because he is always hungry. He likes iPad time, music, walking, movement, and car rides.",
      "createdAt": "2026-04-16T00:01:00.000Z",
      "stepId": "activities_preferences",
      "stepTitle": "Activities & Preferences",
      "promptLabel": "What helps the day go well"
    },
    {
      "id": "gavin-clean-3",
      "role": "user",
      "promptType": "section_prompt",
      "content": "Loud noise, crowds, bright lighting, moved items, and hunger can upset him. Hard transitions or too many demands at once can also overwhelm him.",
      "createdAt": "2026-04-16T00:02:00.000Z",
      "stepId": "upset_overwhelm",
      "stepTitle": "What can upset or overwhelm them",
      "promptLabel": "Triggers"
    },
    {
      "id": "gavin-clean-4",
      "role": "user",
      "promptType": "section_prompt",
      "content": "Signs he needs help include limping, not eating or drinking, low energy, eloping, hand biting, angry vocalizations, hiding when he may be having a bowel movement, and pressing help on his device.",
      "createdAt": "2026-04-16T00:03:00.000Z",
      "stepId": "signs_need_help",
      "stepTitle": "Signs they may need help",
      "promptLabel": "Signs"
    },
    {
      "id": "gavin-clean-5",
      "role": "user",
      "promptType": "section_prompt",
      "content": "When he is still somewhat calm, prompt squeeze and release, deep breaths, or counting to 10. If he is escalating, give space immediately and reduce noise and stimulation. Do not block hand biting because he may bite you. Car rides, quiet environments, and time alone work best as resets.",
      "createdAt": "2026-04-16T00:04:00.000Z",
      "stepId": "hard_time_support",
      "stepTitle": "What helps when they are having a hard time",
      "promptLabel": "Supports"
    },
    {
      "id": "gavin-clean-6",
      "role": "user",
      "promptType": "section_prompt",
      "content": "He needs to be prompted every hour to use the bathroom and does not initiate on his own. Bowel movements happen in a pull-up and he hides and grunts. He eats small amounts constantly, has a limited diet, and will independently get cheese if he is hungry.",
      "createdAt": "2026-04-16T00:05:00.000Z",
      "stepId": "daily_schedule",
      "stepTitle": "Daily Schedule",
      "promptLabel": "Daily needs"
    },
    {
      "id": "gavin-clean-7",
      "role": "user",
      "promptType": "section_prompt",
      "content": "Top safety issues are elopement, hand biting, and unsafe walking. He needs two adults for walks or outings, does not communicate pain, and can become physically unsafe when dysregulated.",
      "createdAt": "2026-04-16T00:06:00.000Z",
      "stepId": "health_safety",
      "stepTitle": "Health & Safety",
      "promptLabel": "Safety"
    },
    {
      "id": "gavin-clean-8",
      "role": "user",
      "promptType": "section_prompt",
      "content": "He enjoys iPad, music, car rides, movement, horseback riding, and exploring new places.",
      "createdAt": "2026-04-16T00:07:00.000Z",
      "stepId": "activities_preferences",
      "stepTitle": "Activities & Preferences",
      "promptLabel": "Enjoys"
    }
  ],
